# Supabase Configuration
# Obtené estos valores desde tu proyecto en https://supabase.com/dashboard/project/_/settings/api

# URL pública de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/Public key (segura para uso en el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role key (SOLO para server-side, NUNCA exponer al cliente)
# Tiene permisos completos para bypassear RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend Configuration
# Obtené tu API key desde https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# Email del remitente (debe estar verificado en Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Email del administrador que recibe notificaciones
ADMIN_EMAIL=admin@yourdomain.com

# Next.js Configuration
# URL base de la aplicación (para webhooks y emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhook secret (genera uno random para validar webhooks de Supabase)
SUPABASE_WEBHOOK_SECRET=your-random-webhook-secret
